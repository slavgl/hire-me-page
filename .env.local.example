NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000

# View notification emails (Resend). If RESEND_API_KEY is unset, tracking still works but no email is sent.
RESEND_API_KEY=
# Must be a verified sender/domain in Resend (e.g. HireMe <notify@yourdomain.com>).
RESEND_FROM=
# Minimum minutes between “new view” emails per page (default 90).
VIEW_NOTIFICATION_THROTTLE_MINUTES=90

# Anthropic: required for upload (resume JSON + job-page “Why I fit”). No heuristic fallback.
ANTHROPIC_API_KEY=
# Optional; default is Haiku 4.5 (successor to claude-3-5-haiku-20241022, deprecated Feb 2026).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Vercel: set the same vars in Project Settings. For long AI calls on upload, set
# maxDuration on the upload route (already 60s in app/api/upload/route.ts); Pro plan
# may be required for >10s serverless duration.
